# Copy this to .env.local and fill in your values

# App URL (set to your Vercel domain after deploy)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp API (optional - for automated order notifications)
# WHATSAPP_API_URL=
# WHATSAPP_API_KEY=
# WHATSAPP_FROM_NUMBER=

# These are NOT needed for the app to work - DB and JWT are no longer required
# DATABASE_URL=
# JWT_SECRET=
